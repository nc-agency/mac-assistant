# Beispiel-Umgebungsvariablen für Mac Assistant
# Erstellt am 2025-05-03
# Kopiere diese Datei zu .env und füge deine API-Keys ein

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Einstellungen
VOICE_ENABLED=true
SCREEN_ANALYSIS_ENABLED=true
